# 复制为 .env 并按需修改；.env 不会被提交（见 .gitignore）

# ---- 安全 ----
# 生产务必改成随机长字符串（如 python -c "import secrets;print(secrets.token_hex(32))"）
JWT_SECRET=change-me-please

# ---- 数据库 ----
# 默认 SQLite（零配置）。如用 PostgreSQL:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/aiqs
# DATABASE_URL=sqlite:///./aiqs.db

# ---- 模型网关（也可登录后在“系统设置”页配置，会覆盖这里）----
# 可选 mock / openai_compat / claude
LLM_PROVIDER=mock
# openai_compat 示例：DeepSeek https://api.deepseek.com/v1 ；通义、豆包、内网 vLLM 同理
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# 内网模式：true 时仅允许内网地址的模型服务（处理敏感资料时开启）
INTRANET_ONLY=false

# ---- 上传限制 ----
MAX_UPLOAD_MB=100

# ---- 题库大类（按本单位实际填写，逗号分隔）----
# 通用示例：
CATEGORIES=公共基础,专业知识,法律法规,安全生产,业务技能,管理知识
# 大类→建议小类（JSON）。例：
# SUBCATEGORIES_JSON={"专业知识": ["网络技术", "业务服务"]}
SUBCATEGORIES_JSON={}
