# ===== 敏感数据 / 运行时产物：绝不能提交 =====
# SQLite 数据库（含模型 API Key、题目、用户口令哈希）
*.db
backend/aiqs.db
# 环境变量（含密钥）
.env
backend/.env
# 上传的资料与导出的题库/试卷（可能含内部敏感材料）
backend/storage/uploads/
backend/storage/exports/
backend/storage/paper_*/
# 运行日志（可能含原文片段）
backend/logs/
# 我方测试脚本产生的临时数据库 / 缓存
*.sqlite

# ===== Python =====
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# ===== 前端 =====
node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*

# ===== 编辑器 / 系统 =====
.vscode/
.idea/
.DS_Store
Thumbs.db

# ===== 内部真实材料：不开源（含真实试题 / 内部文件）=====
templates/*.pdf
templates/题库模版.xlsx
templates/fanxiangicon.jpg
# 但保留通用示例模板
!templates/sample_import_template.xlsx

# ===== 保留占位（让空目录存在）=====
!backend/storage/.gitkeep

# 根目录真实模板（含真题，不开源）
/题库模版.xlsx
